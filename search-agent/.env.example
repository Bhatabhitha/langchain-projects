# Ollama (agents need a model that supports tools, e.g. llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b

# OpenAI (optional)
OPENAI_API_KEY=

# LangSmith EU tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=search-agent

# Search API (add when you pick a provider, e.g. Tavily)
# TAVILY_API_KEY=
